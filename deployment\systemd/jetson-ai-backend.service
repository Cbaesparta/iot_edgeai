[Unit]
Description=Jetson AI IoT Backend (Flask + YOLO + MQTT)
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=__JETSON_USER__
WorkingDirectory=__PROJECT_DIR__
Environment=PYTHONUNBUFFERED=1
ExecStartPre=/bin/bash __PROJECT_DIR__/scripts/wait_for_camera.sh /dev/video0 120
ExecStart=/usr/bin/python3 __PROJECT_DIR__/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
